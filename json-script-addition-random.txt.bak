function playRandomSegment(playlist) {
    const audio = document.getElementById('myPlayer');
    
    // 1. Pick a random file from your JSON array
    const randomIndex = Math.floor(Math.random() * playlist.length);
    const selectedTrack = playlist[randomIndex];
    
    audio.src = selectedTrack.url;

    // 2. Use 'loadedmetadata' to ensure we have the file duration before seeking
    audio.onloadedmetadata = () => {
        // 3. Pick a random start point
        const randomStart = Math.random() * (audio.duration * 0.9);
        
        audio.currentTime = randomStart;
        audio.play();
    };

    // 4. Ensure the NEXT track starts at the BEGINNING
    audio.onended = () => {
        // Select next track sequentially (or pick another random one)
        playNextTrack(); 
    };
}